# Token del bot de Telegram (te lo da @BotFather)
TELEGRAM_TOKEN=123456789:ABCDEF...

# Provider de IA: "gemini" (gratis) o "anthropic" (paid)
AI_PROVIDER=gemini

# API key del provider que elegiste
# Para Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Para Anthropic (solo si usás "anthropic"): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# user_ids autorizados, separados por coma (de @userinfobot)
# Ejemplo: ALLOWED_USER_IDS=12345678,87654321
ALLOWED_USER_IDS=

# Master key para cifrar el JSON.
# Generala con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: guardala en tu password manager. Si la perdés, los datos se pierden.
MASTER_KEY=

# Carpeta de datos. Default: ./data
# DATA_DIR=data
